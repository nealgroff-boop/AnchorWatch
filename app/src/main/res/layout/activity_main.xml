<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121212">

    <!-- Boat position | Anchor position side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚢 Boat"
                android:textColor="#90CAF9"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvBoatPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for GPS..."
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚓ Anchor"
                android:textColor="#90CAF9"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvAnchorPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not set"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- GPS signal info line — colour driven by SNR -->
    <TextView
        android:id="@+id/tvGpsInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accuracy: --  SNR: -- dBHz  Sats: --/--"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvAnchorStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚓ No Anchor Set"
        android:textColor="#90CAF9"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#A5D6A7"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvAlarmStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#EF5350"
        android:textSize="20sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSetAnchor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Anchor Here"
        android:backgroundTint="#1565C0"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnSetAnchorOffset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Anchor by Distance and Bearing"
        android:backgroundTint="#1976D2"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnClearAnchor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Raise Anchor and Clear Track"
        android:backgroundTint="#B71C1C"
        android:enabled="false"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSilence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel Alarm"
        android:backgroundTint="#E65100"
        android:enabled="false"/>

</LinearLayout>
